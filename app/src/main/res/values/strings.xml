    <string name="notif_perm_title">允许通知</string>
    <string name="notif_perm_desc">MonetCanvas 需要通知权限来在后台运行动态壁纸服务。如果拒绝，动态壁纸功能可能受限。</string>
    <string name="notif_perm_allow">允许</string>
    <string name="notif_perm_skip">跳过</string>

    <!-- 动态壁纸服务激活 -->
    <string name="live_wp_setup_title">激活动态壁纸服务</string>
    <string name="live_wp_setup_desc">MonetCanvas 提供动态壁纸服务，可以将视频设为动态壁纸，并自动提取颜色驱动系统 Monet 主题。\n\n点击「激活」后，系统会弹出确认页面。请点击「设置壁纸」完成激活。\n\n即使现在没有导入壁纸也可以先激活，之后随时可以在 App 内设置。</string>
    <string name="live_wp_setup_hint">你也可以稍后在设置动态壁纸时自动激活，不影响使用。</string>
    <string name="live_wp_setup_enable">激活</string>
    <string name="live_wp_setup_later">稍后</string>
    <string name="live_wp_setup_fallback">你的设备不支持直接激活，请在系统壁纸设置中选择 MonetCanvas</string>

    <!-- 动态壁纸设置提示 -->
    <string name="live_wp_file_invalid">视频文件无效或不存在</string>
    <string name="live_wp_chooser_hint">请在列表中找到并选择「MonetCanvas」</string>
    <string name="live_wp_manual_hint">请前往「壁纸」设置，选择「MonetCanvas」动态壁纸</string>
    <string name="live_wp_all_failed">无法打开壁纸设置页。请手动进入系统设置 → 壁纸 → 选择「MonetCanvas」</string>

    <!-- 动态壁纸权限不足弹窗 -->
    <string name="live_wp_perm_title">无法设置动态壁纸</string>
    <string name="live_wp_perm_desc">设置动态壁纸需要先激活 MonetCanvas 的动态壁纸服务。\n\n可能的原因：\n• 动态壁纸服务尚未激活\n• 系统限制了后台服务权限\n• 电池优化阻止了服务运行\n\n请前往系统设置，检查以下项目：\n1. 确认 MonetCanvas 的权限已全部授予\n2. 关闭电池优化（不受限制）\n3. 允许后台活动</string>
    <string name="live_wp_perm_go_settings">前往应用设置</string>
    <string name="live_wp_perm_retry">重试激活</string>

