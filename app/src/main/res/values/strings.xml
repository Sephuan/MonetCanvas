    <!-- 首次启动引导 -->
    <string name="welcome_title">欢迎使用 MonetCanvas</string>
    <string name="welcome_subtitle">一款支持 Material You 动态取色的壁纸管理应用</string>
    <string name="welcome_feature_1">导入静态/动态壁纸，一键设置</string>
    <string name="welcome_feature_2">动态壁纸自动提取颜色，驱动系统 Monet 主题</string>
    <string name="welcome_feature_3">壁纸安全存储在应用私有目录，不受外部删除影响</string>
    <string name="welcome_note">提示：设置动态壁纸时，系统会弹出确认页面，请点击\"设置壁纸\"完成操作。</string>
    <string name="welcome_start">开始使用</string>

