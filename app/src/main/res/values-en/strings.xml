    <!-- Live Wallpaper Setup -->
    <string name="live_wp_setup_title">Activate Live Wallpaper Service</string>
    <string name="live_wp_setup_desc">MonetCanvas provides a live wallpaper service that can set videos as live wallpapers and auto-extract colors for the system Monet theme.\n\nTap "Activate" and the system will show a confirmation page. Tap "Set wallpaper" to complete activation.\n\nYou can activate now even without imported wallpapers. You can set them later anytime.</string>
    <string name="live_wp_setup_hint">You can also activate later when setting a live wallpaper. This won\'t affect usage.</string>
    <string name="live_wp_setup_enable">Activate</string>
    <string name="live_wp_setup_later">Later</string>
    <string name="live_wp_setup_fallback">Your device doesn\'t support direct activation. Please select MonetCanvas in system wallpaper settings.</string>

